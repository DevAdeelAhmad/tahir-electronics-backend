{
  "collectionName": "components_shared_addresses",
  "info": {
    "displayName": "Address",
    "icon": "map-marker-alt",
    "description": "Address information for shipping and billing"
  },
  "options": {},
  "attributes": {
    "addressLine1": {
      "type": "string",
      "required": true
    },
    "addressLine2": {
      "type": "string"
    },
    "city": {
      "type": "string",
      "required": true
    },
    "state": {
      "type": "string",
      "required": true
    },
    "postalCode": {
      "type": "string",
      "required": true
    },
    "country": {
      "type": "string",
      "required": true,
      "default": "United States"
    },
    "isDefault": {
      "type": "boolean",
      "default": false
    },
    "type": {
      "type": "enumeration",
      "enum": ["shipping", "billing", "both"],
      "default": "both"
    }
  }
}
